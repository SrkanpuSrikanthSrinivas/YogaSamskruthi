<%- include('../partials/header') %>
<h1>Admin console</h1>
<div class="stat">
  <div class="s"><b><%= pending %></b><span class="muted">awaiting verification</span></div>
  <div class="s"><b><%= members.filter(m=>m.status==='active').length %></b><span class="muted">active members</span></div>
</div>

<div class="sec-h">Members</div>
<p class="intro">Approve a registration to enable it, reject it, or disable an account. Guruji documents are shown for verification.</p>
<% members.forEach(m => { %>
  <div class="card" style="margin-bottom:12px">
    <div class="row" style="justify-content:space-between">
      <div><h3 style="margin:0"><%= m.name %></h3>
        <div class="tag-row"><span class="pill gold"><%= m.role %></span>
          <% if(m.expertise){ %><span class="pill <%= m.expertise %>"><%= m.expertise %></span><% } %>
          <span class="pill <%= m.status==='active'?'ok':(m.status==='pending'?'wait':'no') %>"><%= m.status %></span></div>
      </div>
    </div>
    <p class="muted"><%= m.role==='guruji' ? m.bio : ('Intention: ' + m.intention) %></p>
    <% if(m.role==='guruji' && m.document_id){ %><a class="doc" href="/media/<%= m.document_id %>" target="_blank">View verification document</a><% } %>
    <% if(m.admin_note){ %><div class="note">Note: <%= m.admin_note %></div><% } %>
    <form method="post" action="/admin/members/<%= m.id %>" style="margin-top:10px">
      <label>Note / reason (optional)</label><input name="note">
      <div class="row" style="margin-top:10px">
        <% if(m.status!=='active'){ %><button class="btn sm" name="status" value="active">Approve &amp; enable</button><% } %>
        <% if(m.status==='pending'){ %><button class="btn no sm" name="status" value="rejected">Reject</button><% } %>
        <% if(m.status==='active'){ %><button class="btn no sm" name="status" value="disabled">Disable</button><% } %>
      </div>
    </form>
  </div>
<% }) %>

<div class="sec-h">Guidelines</div>
<div class="two">
  <div class="card">
    <h3>Add / update guideline</h3>
    <form method="post" action="/admin/guidelines">
      <label>Audience</label><select name="audience"><option value="guruji">Guruji</option><option value="aspirant">Aspirant</option><option value="both">Both</option></select>
      <label>Title</label><input name="title" required>
      <label>Body</label><textarea name="body" rows="5" required></textarea>
      <button class="btn sm" style="margin-top:10px">Save guideline</button>
    </form>
    <p class="muted" style="margin-top:10px">To edit an existing one, copy its text, adjust, and save with the same title.</p>
  </div>
  <div>
    <% guides.forEach(g => { %>
      <div class="card" style="margin-bottom:12px">
        <div class="row" style="justify-content:space-between"><b><%= g.title %></b><span class="pill gold"><%= g.audience %></span></div>
        <p class="muted prose" style="margin:8px 0 0"><%= g.body %></p>
        <form method="post" action="/admin/guidelines" style="margin-top:8px">
          <input type="hidden" name="id" value="<%= g.id %>"><input type="hidden" name="audience" value="<%= g.audience %>">
          <input type="hidden" name="title" value="<%= g.title %>">
          <label>Edit body</label><textarea name="body" rows="4"><%= g.body %></textarea>
          <button class="btn ghost sm" style="margin-top:8px">Update</button>
        </form>
      </div>
    <% }) %>
  </div>
</div>

<div class="sec-h" id="pages">Website pages</div>
<p class="intro">The informational sections carried over from the old site. Edit the text here — changes go live immediately. Untick “Published” to hide a page from the menu.</p>
<% pages.forEach(p => { %>
  <div class="card" style="margin-bottom:12px">
    <div class="row" style="justify-content:space-between">
      <b><%= p.title %></b>
      <a class="muted" href="/learn/<%= p.slug %>" target="_blank">/learn/<%= p.slug %> ↗</a>
    </div>
    <form method="post" action="/admin/pages/<%= p.id %>" style="margin-top:8px">
      <label>Title</label><input name="title" value="<%= p.title %>" required>
      <label>Intro (short line under the title)</label><input name="intro" value="<%= p.intro %>">
      <label>Body</label><textarea name="body" rows="8"><%= p.body %></textarea>
      <label style="display:flex;align-items:center;gap:8px;margin-top:10px"><input type="checkbox" name="published" <%= p.published ? 'checked' : '' %> style="width:auto"> Published</label>
      <button class="btn sm" style="margin-top:10px">Save page</button>
    </form>
  </div>
<% }) %>

<div class="sec-h">Releases</div>
<div class="two">
  <div class="card">
    <h3>Deploy a version</h3>
    <form method="post" action="/admin/releases">
      <label>Version</label><input name="version" placeholder="1.1.0" required>
      <label>Notes</label><textarea name="notes" rows="3"></textarea>
      <button class="btn sm" style="margin-top:10px">Deploy</button>
    </form>
  </div>
  <div>
    <% releases.forEach(r => { %><div class="card" style="margin-bottom:10px"><div class="row" style="justify-content:space-between"><b>v<%= r.version %></b><span class="pill ok"><%= r.status %></span></div><p class="muted"><%= r.notes %></p></div><% }) %>
  </div>
</div>
<%- include('../partials/footer') %>
