<%- include('../partials/header') %>
<h1>Members</h1>
<p class="lede">Pending registrations appear first. Background-verify Gurujis before enabling.</p>
<% users.forEach(u => { %>
  <section class="panel">
    <h3><%= u.name %> <span class="tag"><%= u.role %></span> <span class="tag st-<%= u.status==='active'?'published':(u.status==='pending'?'draft':'archived') %>"><%= u.status %></span></h3>
    <p class="meta"><%= u.email %> &middot; joined <%= u.created_at.slice(0,10) %></p>
    <% if (u.role==='guruji') { %>
      <p><strong>Expertise:</strong> <%= u.expertise %> &middot; <%= u.bio %></p>
      <% if (u.document_path) { %><p><a href="<%= u.document_path %>" target="_blank">View verification document</a></p><% } else { %><p class="meta">No document submitted.</p><% } %>
    <% } else { %>
      <p><strong>Intention:</strong> <%= u.intention %> <span class="meta">target: <%= u.target_date || '—' %></span></p>
    <% } %>
    <% if (u.decision_reason) { %><p class="meta">Note: <%= u.decision_reason %></p><% } %>
    <form method="post" action="/admin/users/<%= u.id %>/status" class="stack">
      <label>Note / reason (optional)<input name="reason"></label>
      <div class="cta-row">
        <% if (u.status!=='active') { %><button class="btn" name="status" value="active">Approve &amp; enable</button><% } %>
        <% if (u.status==='pending') { %><button class="btn ghost" name="status" value="rejected">Reject</button><% } %>
        <% if (u.status==='active') { %><button class="btn ghost" name="status" value="disabled">Disable</button><% } %>
      </div>
    </form>
  </section>
<% }) %>
<%- include('../partials/footer') %>
