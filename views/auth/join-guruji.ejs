<%- include('../partials/header') %>
<div class="auth-wrap">
  <div class="auth-side">
    <div class="eyebrow">Offer your knowledge</div>
    <h2>Teach as a Guruji</h2>
    <p>Following our Guru's example, teaching here is a service to the community. Share what you have practised, with those who genuinely seek it.</p>
    <div class="ticks">
      <div><i>✓</i><span>Background verification before approval</span></div>
      <div><i>✓</i><span>You choose which aspirants to accept</span></div>
      <div><i>✓</i><span>Share posts, videos and hold live sessions</span></div>
    </div>
  </div>
  <div class="auth-form">
    <h1>Register to teach</h1>
    <p class="lead">An admin verifies your background before your account is enabled.</p>
    <div class="auth-tabs"><a href="/login">Sign in</a><a href="/join">Join as aspirant</a><a class="on" href="/teach">Teach</a></div>
    <form method="post" action="/teach" enctype="multipart/form-data">
      <label>Full name</label><input name="name" required>
      <label>Email</label><input type="email" name="email" required>
      <label>Password</label><input type="password" name="password" required minlength="6">
      <label>Area of knowledge</label>
      <select name="expertise"><option value="yoga">Yoga practice</option><option value="farming">Farming practices</option><option value="entrepreneurship">Entrepreneur practices</option></select>
      <label>About you and your practice</label><textarea name="bio" rows="3" placeholder="Years of practice, lineage, what you teach"></textarea>
      <label>Verification document (PDF or image, optional)</label><input type="file" name="document" accept=".pdf,image/*">
      <button class="btn" style="margin-top:18px;width:100%">Submit for verification</button>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
