<%- include('../partials/header') %>
<div class="auth-wrap">
  <div class="auth-side">
    <div class="eyebrow">Welcome back</div>
    <h2>Continue your practice</h2>
    <p>Sign in to reach your Guruji, ask your questions, and join your scheduled sessions.</p>
    <div class="ticks">
      <div><i>✓</i><span>Your applications and their answers</span></div>
      <div><i>✓</i><span>Scheduled audio and video sessions</span></div>
      <div><i>✓</i><span>Guidance and support from the admin team</span></div>
    </div>
  </div>
  <div class="auth-form">
    <h1>Sign in</h1>
    <p class="lead">Use the email you registered with.</p>
    <div class="auth-tabs"><a class="on" href="/login">Sign in</a><a href="/join">Join as aspirant</a><a href="/teach">Teach</a></div>
    <form method="post" action="/login">
      <label>Email</label><input type="email" name="email" required autofocus>
      <label>Password</label><input type="password" name="password" required>
      <button class="btn" style="margin-top:18px;width:100%">Sign in</button>
    </form>
    <p class="muted" style="margin-top:14px">New here? <a href="/join">Join as an aspirant</a> or <a href="/teach">register to teach</a>.</p>
