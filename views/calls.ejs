<%- include('partials/header') %>
<h1>Sessions</h1>
<div class="two">
  <div class="card">
    <h3>Schedule a session</h3>
    <p class="muted">Audio or video — a private meeting link is generated for you.</p>
    <% if(!people.length){ %><div class="empty" style="margin-top:10px">Once you're connected (an accepted application), members appear here.</div>
    <% } else { %>
      <form method="post" action="/calls">
        <label>With</label>
        <select name="participant_id"><% people.forEach(p => { %><option value="<%= p.id %>"><%= p.name %> · <%= p.role %></option><% }) %></select>
        <label>Topic</label><input name="title" placeholder="e.g. Pranayama basics — session 1">
        <label>Date &amp; time</label><input type="datetime-local" name="scheduled_at" required>
        <label>Length (minutes)</label><input type="number" name="minutes" min="10" max="120" value="30">
        <button class="btn sm" style="margin-top:12px">Schedule session</button>
      </form>
    <% } %>
  </div>
  <div>
    <h3>Your sessions</h3>
    <% if(!calls.length){ %><div class="empty">No sessions yet.</div><% } %>
    <% calls.forEach(c => { %>
      <div class="card" style="margin-bottom:12px">
        <div class="row" style="justify-content:space-between"><b><%= c.title %></b><span class="pill <%= c.status==='scheduled'?'ok':'no' %>"><%= c.status %></span></div>
        <p class="muted"><%= c.scheduled_at %> · <%= c.minutes %> min · <%= c.organizer %> ↔ <%= c.participant %></p>
        <% if(c.status==='scheduled'){ %>
          <div class="row"><a class="btn sm gold" href="<%= c.link %>" target="_blank">Join call</a>
          <form method="post" action="/calls/<%= c.id %>/cancel" class="inline"><button class="btn no sm">Cancel</button></form></div>
        <% } %>
      </div>
    <% }) %>
  </div>
</div>
<%- include('partials/footer') %>
