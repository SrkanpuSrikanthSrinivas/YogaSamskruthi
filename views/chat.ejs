<%- include('partials/header') %>
<h1>Chat</h1>
<div class="chat-layout">
  <% if(me.role==='admin'){ %>
    <div class="card">
      <h3>Members</h3>
      <div class="people">
        <% everyone.forEach(t => { %><a href="/chat/<%= t.id %>"><span><%= t.name %></span><span class="pill gold"><%= t.role %></span></a><% }) %>
      </div>
    </div>
  <% } %>
  <div class="card">
    <% if(!withUser){ %><p class="muted">Pick a member to chat with.</p><% } else { %>
      <h3>Chat with <%= withUser.name %></h3>
      <div class="msgs">
        <% if(!msgs.length){ %><p class="muted">No messages yet.</p><% } %>
        <% msgs.forEach(m => { %><div class="msg <%= m.from_id===me.id?'me':'' %>"><%= m.body %></div><% }) %>
      </div>
      <form method="post" action="/chat/<%= withUser.id %>" class="chat-form">
        <input name="body" placeholder="Type a message…" autocomplete="off" required>
        <button class="btn">Send</button>
      </form>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>
