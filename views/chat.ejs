<%- include('partials/header') %>
<h1>Chat</h1>
<div class="chat-layout">
<% if (user.role==='admin') { %>
  <aside class="panel">
    <h3>Threads</h3>
    <% threads.forEach(t => { %><p><a href="/chat/<%= t.id %>"><%= t.name %></a> <span class="tag"><%= t.role %></span></p><% }) %>
    <h3>Start new</h3>
    <% everyone.forEach(t => { %><p><a href="/chat/<%= t.id %>"><%= t.name %></a> <span class="tag"><%= t.role %></span></p><% }) %>
  </aside>
<% } %>
<section class="panel chat-box">
  <% if (!withUser) { %><p class="meta">Pick a member to chat with.</p><% } else { %>
    <h3>Chat with <%= withUser.name %> <span class="tag"><%= withUser.role %></span></h3>
    <div class="msgs">
      <% if (!msgs.length) { %><p class="meta">No messages yet — say namaste.</p><% } %>
      <% msgs.forEach(m => { %>
        <div class="msg <%= m.from_id===user.id ? 'mine' : '' %>">
          <span class="meta"><%= m.from_name %> &middot; <%= fmt(m.created_at,'datetime') %></span>
          <p><%= m.body %></p>
        </div>
      <% }) %>
    </div>
    <form method="post" action="/chat/<%= withUser.id %>" class="chat-form">
      <input name="body" placeholder="Type a message" autocomplete="off" required>
      <button class="btn">Send</button>
    </form>
  <% } %>
</section>
</div>
<%- include('partials/footer') %>
