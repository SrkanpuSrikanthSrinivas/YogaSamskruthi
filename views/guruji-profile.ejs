<%- include('partials/header') %>
<section class="panel">
  <h1><%= g.name %></h1>
  <% (g.expertise||'').split(',').filter(Boolean).forEach(t => { %><span class="tag"><%= t.trim() %></span><% }) %>
  <p><%= g.bio %></p>
  <% if (user && user.role==='aspirant') { %>
    <details class="apply-box">
      <summary class="btn">Apply to learn with <%= g.name.split(' ')[0] %></summary>
      <form method="post" action="/aspirant/apply/<%= g.id %>" class="stack">
        <label>Your intention<textarea name="intention" required placeholder="What do you want to learn, and why?"></textarea></label>
        <label>Target date<input type="date" name="target_date"></label>
        <button class="btn">Send application</button>
      </form>
    </details>
  <% } else if (!user) { %>
    <p class="meta"><a href="/register/aspirant">Register as an aspirant</a> to apply.</p>
  <% } %>
</section>
<h2>Published by <%= g.name %></h2>
<% if (!content.length) { %><p class="meta">Nothing published yet.</p><% } %>
<div class="grid">
<% content.forEach(c => { %>
  <div class="panel">
    <span class="tag type"><%= c.type %></span>
    <h3><% if (c.type==='blog') { %><a href="/blog/<%= c.id %>"><%= c.title %></a><% } else { %><%= c.title %><% } %></h3>
    <% if (c.type==='image' && c.media_path) { %><img src="<%= c.media_path %>" alt="<%= c.title %>" class="media"><% } %>
    <% if (c.type==='video' && c.media_path) { %><video src="<%= c.media_path %>" controls class="media"></video><p class="meta"><%= Math.round(c.duration_seconds/60) %> min</p><% } %>
    <% if (c.type==='event') { %><p class="meta"><%= c.event_date %></p><% } %>
    <p><%= (c.body||'').slice(0,160) %></p>
  </div>
<% }) %>
</div>
<%- include('partials/footer') %>
