<%- include('../partials/header') %>
<h1><%= item ? 'Edit content' : 'New content' %></h1>
<div class="two-col">
<section class="panel">
  <h2>Blog / announcement / event / image</h2>
  <form method="post" action="/guruji/content/save" enctype="multipart/form-data" class="stack">
    <% if (item) { %><input type="hidden" name="id" value="<%= item.id %>"><input type="hidden" name="existing_image_id" value="<%= item.image_id || '' %>"><% } %>
    <label>Type
      <select name="type">
        <% ['blog','announcement','event','image'].forEach(t => { %>
          <option value="<%= t %>" <%= item && item.type===t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>
    </label>
    <label>Title<input name="title" required value="<%= item ? item.title : '' %>"></label>
    <label>Body<textarea name="body" rows="6"><%= item ? item.body : '' %></textarea></label>
    <label>Event date &amp; time (for calendar events)<input type="datetime-local" name="event_date" value="<%= item ? item.event_date : '' %>"></label>
    <label>Image (for image posts &amp; blog covers, max 4&nbsp;MB)<input type="file" name="image" accept="image/*"></label>
    <button class="btn">Save draft</button>
  </form>
</section>
<section class="panel">
  <h2>Video (5–10 min)</h2>
  <p class="meta">Host the clip on YouTube or Vimeo and paste the link — it embeds on your profile. This keeps playback fast and within the 5–10 minute guideline.</p>
  <form method="post" action="/guruji/content/video" class="stack">
    <label>Title<input name="title" required></label>
    <label>Description<textarea name="body" rows="3"></textarea></label>
    <label>YouTube / Vimeo link<input name="video_url" required placeholder="https://youtu.be/..."></label>
    <button class="btn">Save video draft</button>
  </form>
</section>
</div>
<%- include('../partials/footer') %>
