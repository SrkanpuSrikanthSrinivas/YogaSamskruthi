<%- include('partials/header') %>
<h1>Gurujis</h1>
<p class="lede">Choose based on your intention — every Guruji here has passed background verification.</p>
<div class="grid">
<% gurujis.forEach(g => { %>
  <div class="panel">
    <h3><a href="/gurujis/<%= g.id %>"><%= g.name %></a></h3>
    <% (g.expertise||'').split(',').filter(Boolean).forEach(t => { %><span class="tag"><%= t.trim() %></span><% }) %>
    <p><%= g.bio %></p>
  </div>
<% }) %>
</div>
<%- include('partials/footer') %>
