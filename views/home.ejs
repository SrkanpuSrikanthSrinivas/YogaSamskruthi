<%- include('partials/header') %>
<section class="hero">
  <p class="eyebrow">A samskruthi of shared knowledge</p>
  <h1 class="display">Complete involvement.<br>Continuous knowledge.<br>Applied practice.</h1>
  <p class="lede">Yogasamskruthi connects Gurujis with aspirants across yoga practice, natural farming, and entrepreneurship — learn directly, ask directly, practice deliberately.</p>
  <div class="cta-row">
    <a class="btn" href="/gurujis">Find your Guruji</a>
    <a class="btn ghost" href="/register/guruji">Teach as a Guruji</a>
  </div>
</section>

<% if (announcements.length) { %>
<section>
  <h2>Announcements</h2>
  <% announcements.forEach(a => { %>
    <div class="panel announce">
      <strong><%= a.title %></strong>
      <p><%= a.body %></p>
      <span class="meta">by <%= a.author %></span>
    </div>
  <% }) %>
</section>
<% } %>

<div class="two-col">
  <section>
    <h2>Latest writing</h2>
    <% if (!blogs.length) { %><p class="meta">No published posts yet.</p><% } %>
    <% blogs.forEach(b => { %>
      <article class="panel">
        <h3><a href="/blog/<%= b.id %>"><%= b.title %></a></h3>
        <p><%= b.body.slice(0,140) %>&hellip;</p>
        <span class="meta">by <%= b.author %></span>
      </article>
    <% }) %>
  </section>
  <section>
    <h2>Upcoming sessions</h2>
    <% if (!events.length) { %><p class="meta">No published events yet.</p><% } %>
    <% events.forEach(e => { %>
      <div class="panel">
        <strong><%= e.title %></strong>
        <p class="meta"><%= e.event_date %> &middot; <%= e.author %></p>
        <p><%= e.body %></p>
      </div>
    <% }) %>
  </section>
</div>
<%- include('partials/footer') %>
