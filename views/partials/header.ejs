<!DOCTYPE html><html lang="en"><head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Yogasamskruthi</title><link rel="stylesheet" href="/css/style.css">
</head><body>
<div class="top">
  <div class="toprow">
    <a class="brand" href="/">Yoga<b>samskruthi</b></a>
    <nav class="main">
      <a href="/">Home</a>
      <div class="dd"><a href="#">Learn ▾</a>
        <div class="dd-menu">
          <% (navPages||[]).forEach(p => { %><a href="/learn/<%= p.slug %>"><%= p.title %></a><% }) %>
        </div>
      </div>
      <a href="/guidelines">Guidelines</a>
      <% if (me) { %>
        <a href="/<%= me.role %>">Dashboard</a>
        <a href="/calls">Sessions</a>
        <a href="/chat">Chat</a>
        <form method="post" action="/logout" class="inline"><button class="link-btn">Sign out</button></form>
      <% } else { %>
        <a href="/login">Sign in</a>
        <a href="/join">Join</a>
      <% } %>
    </nav>
  </div>
  <div class="kolam"></div>
</div>
<main><div class="wrap">
<% if (flash) { %><div class="flash"><%= flash %></div><% } %>
