<%- include('../partials/header') %>

<!-- Hero -->
<div class="hero">
  <div>
    <div class="eyebrow">Yoga — the refined way of life</div>
    <h1>Yoga has become an indivisible part of our life, by the grace of Guru.</h1>
    <p>Yogasamskruthi is dedicated to our Guru with respect and devotion — a place to preserve his teachings and share the knowledge of yoga, meditation, ayurveda, and trekking with all who seek it.</p>
    <div class="row" style="margin-top:18px">
      <% if (!me) { %>
        <a class="btn" href="/join">Join as an aspirant</a>
        <a class="btn ghost" href="/teach">Teach as a Guruji</a>
      <% } else { %>
        <a class="btn" href="/<%= me.role %>">Go to my dashboard</a>
      <% } %>
    </div>
  </div>
  <%- include('../partials/mandala') %>
</div>

<!-- About -->
<div class="band">
  <div class="sec-h">About Yogasamskruthi</div>
  <p class="intro" style="max-width:80ch">We share the knowledge of Yoga and Trekking, hoping it serves interested friends. Yoga here is not exercise alone — it is a refined way of living: asana, breath, meditation, ayurveda, and time spent in nature, practised as a service rather than sold. Celebrate the practice and experience the bliss in every moment.</p>
</div>

<!-- Lineage / teachers -->
<div class="sec-h">Our lineage &amp; teachers</div>
<p class="intro">The masters whose path we walk, and the teachers who carry the tradition forward today.</p>
<div class="grid">
  <div class="card feature">
    <span class="pill gold">In memory</span>
    <h3 style="margin-top:8px">Yoga Guru Narasimhamurthy (1934–2016)</h3>
    <p class="muted">A realised yogi who attained a high position in Astanga yoga through penance, blessed by Lord Shiva and trained by Himalayan yogis. He never sold yoga — he taught over 25,000 students across India as a service to the Almighty, under Acharya Sri Adi Shankara Yoga Kendra. This platform preserves his teachings.</p>
  </div>
  <% gurus.forEach(g => { %>
    <div class="card">
      <span class="pill <%= g.expertise %>"><%= g.expertise %></span>
      <h3 style="margin-top:8px"><a href="/gurujis/<%= g.id %>"><%= g.name %></a></h3>
      <p class="muted"><%= (g.bio||'').slice(0,220) %><%= (g.bio||'').length>220?'…':'' %></p>
      <a class="btn ghost sm" href="/gurujis/<%= g.id %>" style="margin-top:10px">View profile &amp; posts</a>
    </div>
  <% }) %>
</div>

<!-- What we share -->
<div class="sec-h">What we share</div>
<p class="intro">Explore the knowledge, section by section — carried over and kept alive here.</p>
<div class="grid tiles">
  <% (navPages||[]).forEach(p => { %>
    <a class="tile" href="/learn/<%= p.slug %>">
      <span class="tile-name"><%= p.title %></span>
      <span class="tile-go">Explore →</span>
    </a>
  <% }) %>
</div>

<!-- How it works -->
<div class="sec-h">How it works</div>
<div class="grid">
  <div class="card step"><span class="num">1</span><h3>Register your intention</h3><p class="muted">Join as an aspirant and tell us what you wish to learn and by when. Signing up takes a minute.</p></div>
  <div class="card step"><span class="num">2</span><h3>Choose your Guruji</h3><p class="muted">Read the teachers' profiles and posts, then apply to the one whose path matches your intention.</p></div>
  <div class="card step"><span class="num">3</span><h3>Learn &amp; practise</h3><p class="muted">Once accepted, ask questions and meet your Guruji in scheduled audio or video sessions.</p></div>
</div>
<div class="row" style="margin-top:16px">
  <% if (!me) { %><a class="btn" href="/join">Begin as an aspirant</a><a class="btn ghost" href="/teach">Offer to teach</a><% } %>
</div>

<!-- Guidelines -->
<div class="sec-h">Guidelines &amp; values</div>
<div class="two">
  <% guides.forEach(g => { %>
    <div class="card"><span class="pill gold"><%= g.audience %></span><h3 style="margin-top:8px"><%= g.title %></h3><p class="muted prose"><%= g.body %></p></div>
  <% }) %>
</div>

<!-- Contact -->
<div class="band contact">
  <div class="sec-h">Get in touch</div>
  <p class="intro">For any questions, corrections, or to offer your service to the community, write to us.</p>
  <a class="btn" href="mailto:yoga.samskruthi@gmail.com">yoga.samskruthi@gmail.com</a>
</div>

<%- include('../partials/footer') %>
