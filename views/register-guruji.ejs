<%- include('partials/header') %>
<section class="panel narrow">
  <h1>Register as a Guruji</h1>
  <p class="lede">Background verification is done before registration is accepted. Attach any relevant document (certification, reference, ID) to speed this up.</p>
  <form method="post" action="/register/guruji" enctype="multipart/form-data" class="stack">
    <label>Full name<input name="name" required></label>
    <label>Email<input type="email" name="email" required></label>
    <label>Password<input type="password" name="password" required minlength="8"></label>
    <label>Area of knowledge
      <select name="expertise"><option value="yoga">Yoga practice</option><option value="farming">Farming practices</option><option value="entrepreneurship">Entrepreneur practices</option></select>
    </label>
    <label>About you &amp; your practice<textarea name="bio" rows="4"></textarea></label>
    <label>Verification document (PDF or image, optional)<input type="file" name="document" accept=".pdf,image/*"></label>
    <button class="btn">Submit for verification</button>
  </form>
</section>
<%- include('partials/footer') %>
